<svg width="600" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="petcareGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FF8C42;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#E63946;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="600" height="400" fill="url(#petcareGradient)"/>
  
  <!-- Shop shelves -->
  <rect x="50" y="120" width="500" height="180" fill="rgba(255,255,255,0.1)" stroke="white" stroke-width="2" rx="8"/>
  
  <!-- Shelf 1 -->
  <line x1="60" y1="180" x2="540" y2="180" stroke="white" stroke-width="2"/>
  <!-- Shelf 2 -->
  <line x1="60" y1="240" x2="540" y2="240" stroke="white" stroke-width="2"/>
  <!-- Shelf 3 -->
  <line x1="60" y1="280" x2="540" y2="280" stroke="white" stroke-width="2"/>
  
  <!-- Product boxes on shelves -->
  <rect x="80" y="145" width="40" height="30" fill="#FFD700" stroke="white" stroke-width="1"/>
  <rect x="140" y="145" width="40" height="30" fill="#FF6B6B" stroke="white" stroke-width="1"/>
  <rect x="200" y="145" width="40" height="30" fill="#4ECDC4" stroke="white" stroke-width="1"/>
  <rect x="260" y="145" width="40" height="30" fill="#95E1D3" stroke="white" stroke-width="1"/>
  <rect x="320" y="145" width="40" height="30" fill="#FF8C42" stroke="white" stroke-width="1"/>
  
  <!-- Pet icons -->
  <g transform="translate(420, 160)">
    <!-- Paw print -->
    <circle cx="0" cy="0" r="6" fill="white"/>
    <circle cx="-12" cy="-8" r="4" fill="white"/>
    <circle cx="12" cy="-8" r="4" fill="white"/>
    <circle cx="-8" cy="10" r="4" fill="white"/>
    <circle cx="8" cy="10" r="4" fill="white"/>
  </g>
  
  <!-- Text -->
  <text x="300" y="340" font-size="48" font-weight="bold" fill="white" text-anchor="middle" font-family="Arial">Petcare</text>
  <text x="300" y="375" font-size="16" fill="rgba(255,255,255,0.95)" text-anchor="middle" font-family="Arial">Pet Supplies &amp; Care Store</text>
</svg>